<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="multy_aruco_test_world">

    <!-- Physics -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Plugins -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>

    <!-- Light -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Ground -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ===== ARUCO MARKERS (WALL SETUP) ===== -->

    <include>
      <uri>model://aruco_0</uri>
      <name>aruco_marker_0</name>
      <pose>3 -2 1 0 0 1.5708</pose>
    </include>

    <include>
      <uri>model://aruco_1</uri>
      <name>aruco_marker_1</name>
      <pose>3 -1 1 0 0 1.5708</pose>
    </include>

    <include>
      <uri>model://aruco_2</uri>
      <name>aruco_marker_2</name>
      <pose>3 0 1 0 0 1.5708</pose>
    </include>

    <include>
      <uri>model://aruco_3</uri>
      <name>aruco_marker_3</name>
      <pose>3 1 1 0 0 1.5708</pose>
    </include>

    <include>
      <uri>model://aruco_10</uri>
      <name>aruco_marker_10</name>
      <pose>3 2 1 0 0 1.5708</pose>
    </include>

    <include>
      <uri>model://aruco_23</uri>
      <name>aruco_marker_23</name>
      <pose>5 -1 1 0 0 1.5708</pose>
    </include>

    <include>
      <uri>model://aruco_42</uri>
      <name>aruco_marker_42</name>
      <pose>5 1 1 0 0 1.5708</pose>
    </include>

  </world>
</sdf>